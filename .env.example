# ============================================================
# AnnotateOS v4 — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ── Database (required) ───────────────────────────────────────
# PostgreSQL connection string. Railway provides this automatically.
# Supports both DATABASE_URL and DATABASE_PRIVATE_URL
DATABASE_URL=postgresql://user:password@host:5432/annotatedb
# DATABASE_PRIVATE_URL=postgresql://user:password@internal-host:5432/annotatedb

# ── Auth session (required) ───────────────────────────────────
# JWT secret key for session tokens (min 32 characters recommended)
# Can also use JWT_SECRET instead of SESSION_SECRET
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars
# JWT_SECRET=change_me_to_a_long_random_string_min_32_chars

# ── Server ────────────────────────────────────────────────────
# PORT: Server port (default: 3000 for local, Railway uses 3000)
# NOTE: Railway will override this with its own PORT variable if set
PORT=3000
NODE_ENV=production

# ── Admin Bootstrap (optional — auto-create first admin on startup) ────
# If set, the server will automatically create an admin account on first run
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_secure_password
ADMIN_NAME=Administrator

# ── Setup Token (optional — protect initial setup endpoint) ────
# If set, /api/auth/setup endpoint requires this token
SETUP_TOKEN=

# ── Google OAuth (optional — enables Google login) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google AI (optional — enables AI pre-annotation & QA) ────
GEMINI_API_KEY=

# ── AWS S3 (optional — enables media file uploads) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ── Label Studio (optional — sync integration) ────────────────
LABEL_STUDIO_URL=
LABEL_STUDIO_API_KEY=

# ── Redis (optional — BullMQ upgrade path for workers) ────────
# Leave blank to use in-process setInterval workers (default)
REDIS_URL=

# ── Manus/Forge API (optional — for advanced features) ────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Owner OpenId (optional — auto-promote user to admin) ──────
OWNER_OPEN_ID=

# ── Feature flags ─────────────────────────────────────────────
ENABLE_IAA_WORKER=true
ENABLE_STATS_WORKER=true
ENABLE_EXPIRY_WORKER=true
SKIP_RATE_LIMIT=3
