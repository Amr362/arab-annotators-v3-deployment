# ============================================================
# AnnotateOS v4 — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ============================================================

# ── Database (required) ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/annotatedb

# ── Auth session (required) ───────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Google AI (optional — enables AI pre-annotation & QA) ────
GEMINI_API_KEY=

# ── AWS S3 (optional — enables media file uploads) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ── Label Studio (optional — sync integration) ────────────────
LABEL_STUDIO_URL=
LABEL_STUDIO_API_KEY=

# ── Redis (optional — BullMQ upgrade path for workers) ────────
# Leave blank to use in-process setInterval workers (default)
REDIS_URL=

# ── Feature flags ─────────────────────────────────────────────
ENABLE_IAA_WORKER=true
ENABLE_STATS_WORKER=true
ENABLE_EXPIRY_WORKER=true
SKIP_RATE_LIMIT=3
