{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildArgs": {
      "VITE_GOOGLE_CLIENT_ID": "${{VITE_GOOGLE_CLIENT_ID}}"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "preDeployCommand": "pnpm db:push",
    "startCommand": "pnpm start",
    "restartPolicyMaxRetries": 10
  }
}
