{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm install && pnpm db:push && node dist/index.js",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/api/health",
    "healthCheckTimeout": 10
  }
}
